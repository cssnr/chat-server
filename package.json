{
  "name": "chat-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "npx tsc",
    "dev": "nodemon --exec tsx src/index.ts",
    "lint": "npx eslint src",
    "prepare": "npm run build",
    "prettier:": "npm run prettier:write",
    "prettier:check": "npx prettier --check .",
    "prettier:write": "npx prettier --write .",
    "start": "node dist/index.js",
    "tsc": "npx tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.3",
    "@ai-sdk/google": "^4.0.3",
    "@ai-sdk/openai": "^4.0.4",
    "@ai-sdk/openai-compatible": "^3.0.2",
    "ai": "^7.0.8",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "picomatch": "^4.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.1",
    "@types/picomatch": "^4.0.3",
    "eslint": "^10.6.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.9.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  }
}
